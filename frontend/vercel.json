{
  "redirects": [
    { "source": "/share/:slug", "destination": "/api/share?slug=:slug", "permanent": false }
  ],
  "routes": [
    { "src": "/api/share", "dest": "/api/share" },
    { "src": "/api/public/(.*)", "dest": "https://weegols.onrender.com/api/public/$1" },
    { "src": "/api/(.*)", "dest": "https://weegols.onrender.com/api/$1" },
    { "src": "/uploads/(.*)", "dest": "https://weegols.onrender.com/uploads/$1" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
